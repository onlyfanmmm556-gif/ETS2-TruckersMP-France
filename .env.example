# ─────────────────────────────────────────────
# Variables d'environnement — Bot Trucky Discord
# Copiez ce fichier en .env pour un test local
# Sur Railway : configurez directement dans Variables
# ─────────────────────────────────────────────

# Token du bot Discord (Developer Portal > Bot > Token)
DISCORD_TOKEN=your_discord_bot_token_here

# ID du salon Discord où envoyer les stats
# (clic droit sur le salon > Copier l'identifiant)
CHANNEL_ID=your_channel_id_here

# Intervalle de mise à jour (format cron)
# "0 * * * *"   = toutes les heures (défaut)
# "0 */2 * * *" = toutes les 2 heures
# "0 8 * * *"   = tous les jours à 8h
STATS_INTERVAL=0 * * * *

# Nombre max d'entreprises dans le classement (défaut: 10)
MAX_COMPANIES=10

# Nom de votre bot (utilisé comme User-Agent pour l'API Trucky)
# NE PAS laisser vide — l'API Trucky bloque les User-Agent vides
BOT_NAME=TruckyStatsBotFR
